# ── Postgres ──────────────────────────────────────────
POSTGRES_USER=synq
POSTGRES_PASSWORD=synq_dev_password
POSTGRES_DB=synq_dev

# ── Redis (two instances: cache on 6379, queue on 6380) ──
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6380/0

# ── MinIO (local S3-compatible storage) ───────────────
MINIO_ROOT_USER=synq_minio
MINIO_ROOT_PASSWORD=synq_minio_password
