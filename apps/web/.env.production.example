# Production env reference for the SYNQ web app (Vercel).
#
# Paste these into Vercel → Project → Settings → Environment Variables.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser (safe for URLs
# and publishable keys); CLERK_SECRET_KEY stays server-only.

# Your deployed Render API base URL (NO trailing slash).
NEXT_PUBLIC_API_URL=https://synq-api.onrender.com
# Your Vercel site URL (set after the first deploy assigns one).
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Clerk — from https://dashboard.clerk.com → API Keys ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_test_xxx
CLERK_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat
