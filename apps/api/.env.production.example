# Production env reference for the SYNQ API (Render).
#
# You do NOT create this file on a server — these are the values you paste
# into Render → your synq-api service → Environment. This file just lists
# every key with the format each managed provider expects. See DEPLOY.md
# for where to click to get each value.

# ── App ───────────────────────────────────────────────
ENVIRONMENT=production
# Render generates SECRET_KEY for you (generateValue in render.yaml).
SECRET_KEY=
# Run Celery tasks in-process (no separate worker) to fit free 512MB.
CELERY_EAGER=true
# JSON array of allowed browser origins = your Vercel URL(s). Fill in
# after the first Vercel deploy. NOTE: must be valid JSON, with brackets.
CORS_ORIGINS=["https://your-app.vercel.app"]

# ── Postgres (Neon) ───────────────────────────────────
# Neon dashboard → Connection Details → "Pooled connection" string.
# KEEP the ?sslmode=require suffix — the app needs it to enable TLS.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/synq?sslmode=require

# ── Redis ─────────────────────────────────────────────
# Provisioned by render.yaml (synq-redis). Render fills these in
# automatically via fromService — you normally leave them untouched.
REDIS_URL=
REDIS_QUEUE_URL=

# ── Object storage (Cloudflare R2) ───────────────────
# R2 dashboard → bucket → Settings (endpoint) and "Manage R2 API Tokens".
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_r2_access_key_id
S3_SECRET_KEY=your_r2_secret_access_key
S3_BUCKET=synq-files

# ── Vector DB (Qdrant Cloud) ─────────────────────────
# Qdrant Cloud → your cluster → "Cluster URL" + an API key.
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# ── Clerk auth ────────────────────────────────────────
# Clerk dashboard → API Keys / Advanced. Issuer = Frontend API URL, no
# trailing slash. Webhook secret from Clerk → Webhooks → your endpoint.
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_xxx

# ── LLM provider keys (all free tier) ────────────────
GEMINI_API_KEY=          # https://aistudio.google.com/apikey
MISTRAL_API_KEY=         # https://console.mistral.ai  (used for embeddings)
GROQ_API_KEY=            # https://console.groq.com/keys (summaries + vision)
DEFAULT_MODEL=gemini-2.5-flash
