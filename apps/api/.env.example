# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://synq:synq_dev_password@localhost:5432/synq_dev

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6380/0

# ── Object storage (MinIO locally, S3/R2 in prod) ────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=synq_minio
S3_SECRET_KEY=synq_minio_password
S3_BUCKET=synq-files

# ── App ───────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# ── Clerk auth ────────────────────────────────────────
# Find these in your Clerk dashboard.
# JWKS endpoint: dashboard → API Keys → "Advanced" → JWKS URL
# Issuer:        same as your Clerk frontend API URL (no trailing slash)
# Webhook secret: dashboard → Webhooks → endpoint → Signing Secret
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_WEBHOOK_SECRET=

# ── LLM ───────────────────────────────────────────────
# Free tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash

# ── Rate limit ────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Phase 3 — file pipeline ──────────────────────────
# Hard upload ceiling, enforced before any bytes hit S3.
MAX_FILE_SIZE_MB=20
# Documents over this token count get chunked into ~CHUNK_TARGET_TOKENS
# chunks (Phase 3 stores them in JSONB; Phase 4 wires them into RAG).
CHUNK_TRIGGER_TOKENS=4000
CHUNK_TARGET_TOKENS=500
# Description-generation model. Deliberately CHEAP and SEPARATE from the
# user's selected chat model so file-prep cost is decoupled.
DESCRIPTION_MODEL=groq-llama-vision
# Gemini Files API caches the upload URI in Redis for this many seconds
# before re-uploading. Google's documented retention is 48h; we expire
# slightly earlier to avoid hitting a stale URI.
GEMINI_FILE_TTL_SECONDS=169200
